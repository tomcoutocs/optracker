# Supabase (required for inventory and cards)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: use for sync job to bypass RLS (otherwise anon key is used)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One Piece API via RapidAPI (only used by the daily sync job)
# Get key: https://rapidapi.com/tcggopro/api/one-piece-tcg-prices
RAPIDAPI_KEY=your-rapidapi-key

# Optional: require this header when calling POST /api/sync-cards (e.g. from cron)
# CRON_SECRET=your-random-secret
